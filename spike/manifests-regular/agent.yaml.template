apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: platform-agent-data
  namespace: ${TARGET_NAMESPACE}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 10Gi
---
apiVersion: kagent.dev/v1alpha2
kind: Agent
metadata:
  name: platform-agent
  namespace: ${TARGET_NAMESPACE}
spec:
  description: "Platform Agent Regular Deployment Spike"
  type: BYO
  byo:
    deployment:
      image: ${AGENT_IMAGE}
      serviceAccountName: platform-agent-sa
      podSecurityContext:
        fsGroup: 10001
        runAsUser: 10001
        runAsGroup: 10001
      args:
        - "hermes"
        - "gateway"
        - "run"
      env:
        - name: API_SERVER_PORT
          value: "8080"
        - name: API_SERVER_HOST
          value: "0.0.0.0"
        - name: PYTHONPATH
          value: "/opt/data"
        - name: GOOGLE_CHAT_PROJECT_ID
          value: "${PROJECT_ID}"
        - name: GOOGLE_CHAT_SUBSCRIPTION_NAME
          value: "projects/${PROJECT_ID}/subscriptions/${CHAT_SUB_NAME}"
        - name: GOOGLE_CHAT_ALLOWED_USERS
          value: "${ALLOWED_USERS}"
        - name: GKE_CLUSTER_NAME
          value: "${CLUSTER_NAME}"
        - name: GKE_LOCATION
          value: "${REGION}"
        - name: HERMES_DASHBOARD
          value: "1"
        - name: PLATFORM_AGENT_DASHBOARD
          value: "1"
        - name: PLATFORM_AGENT_PLUGINS_DEBUG
          value: "0"
        - name: API_SERVER_KEY
          valueFrom:
            secretKeyRef:
              name: platform-agent-secrets
              key: API_SERVER_KEY
        - name: GEMINI_API_KEY
          valueFrom:
            secretKeyRef:
              name: platform-agent-secrets
              key: GEMINI_API_KEY
      volumes:
        - name: platform-agent-data-vol
          persistentVolumeClaim:
            claimName: platform-agent-data
        - name: platform-agent-config-vol
          configMap:
            name: platform-agent-config
            defaultMode: 493 # 0755 in decimal
      volumeMounts:
        - name: platform-agent-data-vol
          mountPath: /opt/data
        - name: platform-agent-config-vol
          mountPath: /opt/data/config.yaml
          subPath: config.yaml
        - name: platform-agent-config-vol
          mountPath: /opt/data/sitecustomize.py
          subPath: sitecustomize.py
