# ==========================================
# Core Infrastructure
# ==========================================
PROJECT_ID="your-project-id"
REGION="us-central1"
CLUSTER_NAME="platform-agent-cluster"
NAMESPACE="platform-agent"

# ==========================================
# Artifact Registry & Docker Build
# ==========================================
REPO_NAME="platform-agent-repo"
IMAGE_NAME="platform-agent"
IMAGE_TAG="latest"

# ==========================================
# Google Chat / PubSub Configuration
# ==========================================
CHAT_TOPIC_NAME="platform-agent-chat-events"
CHAT_SUB_NAME="platform-agent-chat-events-sub"
GSA_NAME="platform-agent-chat-bot"
KSA_NAME="platform-agent-chat-bot"

GOOGLE_CHAT_ALLOWED_USERS="your-email@google.com"
GOOGLE_CHAT_HOME_CHANNEL="chat/XXXXXXXXXXX"

# ==========================================
# Secrets 
# ==========================================
GEMINI_API_KEY="your-gemini-api-key"
