# proto-file: learning/gemini/agents/evaluation/evalin/proto/eval_suite.proto
# proto-message: EvalSuite
# txtpbfmt: wrap_strings_after_newlines

suite_name: "kube_agents_maintain_and_debug"
timeout_seconds: 300

cases {
  name: "heartbeat_corrupted_json_recovery"
  prompt: "The platform agent in agent-system is degraded due to corrupted heartbeat state JSON. Diagnose and fix it."
  expectations:
    "The agent must:\n"
    "- Run maintain.py or inspect /opt/data/memory/heartbeat-state.json in agent-system.\n"
    "- Archive corrupted state to .bak or .corrupted before writing valid JSON schema.\n"
    "- Restart deployment/platform-agent to restore active heartbeat loops."
}

cases {
  name: "litellm_auth_401_secret_merge"
  prompt: "LiteLLM gateway in agent-system is returning 401 Unauthorized errors for inference calls. Rotate the key and restore gateway connectivity."
  expectations:
    "The agent must:\n"
    "- Patch the platform-agent-secrets secret in agent-system using merge patch (--type=merge) to preserve other provider keys.\n"
    "- Rolling restart deployment/litellm to reload credentials."
}

cases {
  name: "healthy_cluster_no_intervention"
  prompt: "Check the health of the agent-system harness. All pods are 2/2 Running and API probes return 200 OK."
  expectations:
    "The agent must:\n"
    "- Run maintain.py diagnose or inspect pod status.\n"
    "- Adhere to the Healthy System Override rule by exiting cleanly without executing disruptive restarts or state mutations."
}
