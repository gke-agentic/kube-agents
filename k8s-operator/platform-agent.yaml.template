apiVersion: kubeagents.x-k8s.io/v1alpha1
kind: PlatformAgent
metadata:
  name: platform-agent
  namespace: ${NAMESPACE}
spec:
  harness:
    clusterName: "${CLUSTER_NAME}"
    location: "${REGION}"
    hermes:
      dashboardEnabled: true
      pluginsDebug: false
      platformAgentHome: "/opt/data"
      apiServerSecretRef:
        name: platform-agent-secrets
        key: API_SERVER_KEY
  deployment:
    image: "${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO_NAME}/platform-agent"
    tag: "latest"
    imagePullPolicy: Always
  security:
    serviceAccountName: "${KSA_NAME}"
    workloadIdentity:
      gcp:
        gsaName: "${GSA_NAME}"
        projectId: "${PROJECT_ID}"
  model:
    provider: "gemini"
    default: "gemini-3.1-flash-lite"
    gemini:
      apiKeySecretRef:
        name: platform-agent-secrets
        key: GEMINI_API_KEY
  integration:
    googleChat:
      enabled: true
      projectId: "${PROJECT_ID}"
      topicName: "${CHAT_TOPIC_NAME}"
      subscriptionName: "${CHAT_SUB_NAME}"
      allowedUsers:
        - "${ALLOWED_USER}"
      homeChannel: ""
